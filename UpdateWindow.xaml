<Window x:Class="Jarvis.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Jarvis Update"
        Width="460"
        Height="240"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#08101E">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="JARVIS UPDATE" Foreground="#64E6FF" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock x:Name="VersionText" Text="Проверка обновлений..." Foreground="#DDEEFF" FontSize="13" Margin="0,10,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <TextBlock x:Name="StatusText" Text="Подключаюсь к GitHub Releases..." Foreground="#DDEEFF" TextWrapping="Wrap"/>
            <ProgressBar x:Name="Progress"
                         Height="20"
                         Margin="0,18,0,0"
                         IsIndeterminate="True"/>
            <TextBlock x:Name="NotesText" Foreground="#8EA7C7" TextWrapping="Wrap" Margin="0,12,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="InstallButton"
                    Content="Установить"
                    Width="110"
                    Height="32"
                    IsEnabled="False"
                    Click="InstallButton_Click"
                    Margin="0,0,10,0"/>
            <Button Content="Закрыть"
                    Width="90"
                    Height="32"
                    Click="CloseButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
